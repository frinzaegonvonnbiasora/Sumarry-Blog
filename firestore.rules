rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function: Check if user's email is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Rules for Blog Posts collection
    match /posts/{postId} {
      // 1. READ: Anyone logged in can read published posts. 
      // Authors can read their own drafts.
      allow read: if isSignedIn() && (
        resource.data.status == 'published' || 
        resource.data.authorId == request.auth.uid
      );
      
      // 2. CREATE: Logged in & Verified users can create posts.
      // Must set themselves as the author.
      allow create: if isSignedIn() && 
                    isEmailVerified() &&
                    request.resource.data.authorId == request.auth.uid;
      
      // 3. UPDATE: Authors can update anything. Others can only update likes and commentCount.
        allow update: if isSignedIn() && (
          (isEmailVerified() && resource.data.authorId == request.auth.uid) || 
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount']))
        );
        
        // 4. DELETE: Only the original author can delete their post.
        allow delete: if isSignedIn() && 
                      resource.data.authorId == request.auth.uid;

      // Rules for Comments sub-collection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isEmailVerified() && request.resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }
    
    // Rules for Users collection (Private Assets & Profiles)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      // Private data sub-collection: strictly owned by the user
      match /privateData/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
